{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."]
    },
    "github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "trusted": false
    },
    "internal": {
      "command": "node",
      "args": ["./scripts/my-mcp-server.js"],
      "env": { "API_KEY": "..." },
      "trusted": true
    }
  }
}
